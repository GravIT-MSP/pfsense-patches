+
+/*
+ * Apply GUI settings using "tailscale set" (incremental) rather than "tailscale up" (declarative).
+ * This avoids breakage when non-default prefs exist (e.g. SSH enabled via "tailscale set --ssh").
+ *
+ * Source of truth is /usr/local/etc/rc.conf.d/pfsense_tailscaled, which the GUI already writes.
+ */
+function tailscale_apply_set_from_rcconf(): bool
+{
+	$sh = <<<'SH'
+. /usr/local/etc/rc.conf.d/pfsense_tailscaled 2>/dev/null || exit 0
+TS="/usr/local/bin/tailscale"
+
+accdns="${pfsense_tailscaled_acceptdns_enable:-YES}"
+accroutes="${pfsense_tailscaled_acceptroutes_enable:-NO}"
+exitnode="${pfsense_tailscaled_exitnode_enable:-NO}"
+routes="${pfsense_tailscaled_advertiseroutes:-}"
+
+cmd="$TS set"
+
+if [ "$accdns" = "YES" ]; then
+  cmd="$cmd --accept-dns=true"
+else
+  cmd="$cmd --accept-dns=false"
+fi
+
+if [ "$accroutes" = "YES" ]; then
+  cmd="$cmd --accept-routes=true"
+else
+  cmd="$cmd --accept-routes=false"
+fi
+
+if [ "$exitnode" = "YES" ]; then
+  cmd="$cmd --advertise-exit-node=true"
+else
+  cmd="$cmd --advertise-exit-node=false"
+fi
+
+# IMPORTANT: empty clears advertised routes
+if [ -n "$routes" ]; then
+  cmd="$cmd --advertise-routes=$routes"
+else
+  cmd="$cmd --advertise-routes="
+fi
+
+eval "$cmd"
+SH;
+
+	// run synchronously so the GUI can reflect success/failure
+	return (mwexec("/bin/sh -c " . escapeshellarg($sh), false, false, false) === 0);
 }
 
+
